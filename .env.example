# OrthoAndSpineTools — production environment template
# Copy to .env and fill in real values. Never commit .env with secrets.

# PostgreSQL (must match DATABASE_URL password)
POSTGRES_PASSWORD=change_me_strong_password

# Backend / Prisma — add pool settings for scalability
# Example: postgresql://postgres:PASSWORD@postgres:5432/orthoandspinetools?connection_limit=10&pool_timeout=20
# DATABASE_URL is set in docker-compose for backend; override here if using external DB:
# DATABASE_URL=postgresql://postgres:change_me_strong_password@postgres:5432/orthoandspinetools?connection_limit=10&pool_timeout=20

JWT_SECRET=change_me_min_32_chars_random_string
JWT_EXPIRES_IN=7d

# Optional: comma-separated extra origins for CORS
# CORS_ORIGINS=https://orthoandspinetools.com,https://www.orthoandspinetools.com

# Rate limiting (optional overrides for Express)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Node memory cap (optional, MB)
# NODE_OPTIONS=--max-old-space-size=2048

# --- Frontend build (Vite) ---
# If unset, the app uses same-origin `/api` (Vite dev proxy → backend, or nginx `/api/` in production).
# Set VITE_API_URL only when the API is on another origin (full base including /api, no trailing slash).
# docker-compose.prod.yml may set a build-arg; runtime env does not change an already-built bundle.
# VITE_API_URL=https://orthoandspinetools.com/api
